<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- Auth flow -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.intprogactivity.presentation.splash.SplashFragment"
        android:label="Splash"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.intprogactivity.presentation.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_forgot_password"
            app:destination="@id/forgotPasswordFragment" />
        <action
            android:id="@+id/action_login_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.intprogactivity.presentation.auth.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_register_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/forgotPasswordFragment"
        android:name="com.example.intprogactivity.presentation.auth.ForgotPasswordFragment"
        android:label="Forgot Password"
        tools:layout="@layout/fragment_forgot_password">
        <action
            android:id="@+id/action_forgot_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Main tabs -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.intprogactivity.presentation.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_search_results"
            app:destination="@id/searchResultsFragment" />
    </fragment>

    <!-- Search -->
    <fragment
        android:id="@+id/searchResultsFragment"
        android:name="com.example.intprogactivity.presentation.search.SearchResultsFragment"
        android:label="Search Results"
        tools:layout="@layout/fragment_search_results">
        <argument
            android:name="searchParamsJson"
            app:argType="string"
            android:defaultValue="" />
        <action
            android:id="@+id/action_results_to_detail"
            app:destination="@id/flightDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/flightDetailFragment"
        android:name="com.example.intprogactivity.presentation.search.FlightDetailFragment"
        android:label="Flight Detail"
        tools:layout="@layout/fragment_flight_detail">
        <argument
            android:name="flightOfferJson"
            app:argType="string" />
        <action
            android:id="@+id/action_detail_to_passenger"
            app:destination="@id/passengerDetailsFragment" />
    </fragment>

    <!-- Booking nested flow -->
    <fragment
        android:id="@+id/passengerDetailsFragment"
        android:name="com.example.intprogactivity.presentation.booking.PassengerDetailsFragment"
        android:label="Passenger Details"
        tools:layout="@layout/fragment_passenger_details">
        <action
            android:id="@+id/action_passenger_to_addons"
            app:destination="@id/addOnsFragment" />
    </fragment>

    <fragment
        android:id="@+id/addOnsFragment"
        android:name="com.example.intprogactivity.presentation.booking.AddOnsFragment"
        android:label="Add-Ons"
        tools:layout="@layout/fragment_add_ons">
        <action
            android:id="@+id/action_addons_to_seat_map"
            app:destination="@id/seatMapFragment" />
        <action
            android:id="@+id/action_addons_to_checkout"
            app:destination="@id/checkoutFragment" />
    </fragment>

    <fragment
        android:id="@+id/seatMapFragment"
        android:name="com.example.intprogactivity.presentation.booking.SeatMapFragment"
        android:label="Seat Selection"
        tools:layout="@layout/fragment_seat_map">
        <action
            android:id="@+id/action_seats_to_checkout"
            app:destination="@id/checkoutFragment" />
    </fragment>

    <fragment
        android:id="@+id/checkoutFragment"
        android:name="com.example.intprogactivity.presentation.booking.CheckoutFragment"
        android:label="Checkout"
        tools:layout="@layout/fragment_checkout">
        <action
            android:id="@+id/action_checkout_to_confirmation"
            app:destination="@id/confirmationFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <fragment
        android:id="@+id/confirmationFragment"
        android:name="com.example.intprogactivity.presentation.booking.ConfirmationFragment"
        android:label="Confirmed"
        tools:layout="@layout/fragment_confirmation">
        <argument
            android:name="bookingId"
            app:argType="string" />
        <action
            android:id="@+id/action_confirmation_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_confirmation_to_trips"
            app:destination="@id/tripsFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="false" />
    </fragment>

    <!-- My Trips -->
    <fragment
        android:id="@+id/tripsFragment"
        android:name="com.example.intprogactivity.presentation.trips.TripsFragment"
        android:label="My Trips"
        tools:layout="@layout/fragment_trips">
        <action
            android:id="@+id/action_trips_to_booking_detail"
            app:destination="@id/bookingDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/bookingDetailFragment"
        android:name="com.example.intprogactivity.presentation.trips.BookingDetailFragment"
        android:label="Booking Detail"
        tools:layout="@layout/fragment_booking_detail">
        <argument
            android:name="bookingId"
            app:argType="string" />
    </fragment>

    <!-- Profile -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.intprogactivity.presentation.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profile_to_alerts"
            app:destination="@id/priceAlertsFragment" />
        <action
            android:id="@+id/action_profile_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/priceAlertsFragment"
        android:name="com.example.intprogactivity.presentation.profile.PriceAlertsFragment"
        android:label="Price Alerts"
        tools:layout="@layout/fragment_price_alerts" />

    <!-- Rewards -->
    <fragment
        android:id="@+id/rewardsFragment"
        android:name="com.example.intprogactivity.presentation.rewards.RewardsFragment"
        android:label="Rewards"
        tools:layout="@layout/fragment_rewards" />

</navigation>
