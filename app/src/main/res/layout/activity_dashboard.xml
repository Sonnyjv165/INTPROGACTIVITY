<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/tropic"
    android:backgroundTint="#78FAFAFA"
    android:backgroundTintMode="screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ── HERO HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:paddingTop="48dp"
            android:background="#1A73E8">

            <!-- Top row: greeting + avatar -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_centerVertical="true">

                    <TextView
                        android:text="Good morning 👋"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#CCE8FF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/welcomeText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome back, Juan!"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                </LinearLayout>

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true">

                    <ImageView
                        android:id="@+id/profileIcon"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:src="@android:drawable/ic_menu_myplaces"
                        android:background="@drawable/circle_bg"
                        android:padding="8dp"
                        app:tint="#FFFFFF" />
                </FrameLayout>
            </RelativeLayout>

            <!-- Search bar -->
            <EditText
                android:id="@+id/searchInput"
                android:hint="Where to?"
                android:textColorHint="#90B8E0"
                android:background="@drawable/input_bg"
                android:textColor="#1E2A38"
                android:padding="14dp"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- ── QUICK-ACCESS ICON GRID ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:paddingTop="20dp"
            android:paddingBottom="8dp">

            <!-- Row 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:gravity="center">

                <!-- Flights -->
                <LinearLayout
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/icon_pill_blue">
                        <ImageView
                            android:id="@+id/flightsIcon"
                            android:src="@drawable/airplane_icon_png_2493"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"/>
                    </FrameLayout>
                    <TextView
                        android:text="Flights"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#1E2A38"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Hotels -->
                <LinearLayout
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/icon_pill_orange">
                        <ImageView
                            android:id="@+id/hotelsIcon"
                            android:src="@android:drawable/ic_menu_compass"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                    <TextView
                        android:text="Hotels"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#1E2A38"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Attractions -->
                <LinearLayout
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/icon_pill_green">
                        <ImageView
                            android:id="@+id/attractionsIcon"
                            android:src="@android:drawable/ic_menu_mapmode"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                    <TextView
                        android:text="Attractions"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#1E2A38"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Car Rental -->
                <LinearLayout
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/icon_pill_purple">
                        <ImageView
                            android:id="@+id/carIcon"
                            android:src="@android:drawable/ic_menu_directions"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                    <TextView
                        android:text="Car Rental"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#1E2A38"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp"
                android:gravity="center">

                <!-- Trains -->
                <LinearLayout
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/icon_pill_teal">
                        <ImageView
                            android:src="@android:drawable/ic_menu_recent_history"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                             app:tint="#FFFFFF" />
                    </FrameLayout>
                    <TextView
                        android:text="Trains"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#1E2A38"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Transfers -->
                <LinearLayout
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/icon_pill_red">
                        <ImageView
                            android:src="@android:drawable/ic_menu_share"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                    <TextView
                        android:text="Transfers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#1E2A38"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- Visa -->
                <LinearLayout
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/icon_pill_yellow">
                        <ImageView
                            android:src="@android:drawable/ic_menu_info_details"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                    <TextView
                        android:text="Visa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#1E2A38"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>

                <!-- More -->
                <LinearLayout
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="8dp">
                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/icon_pill_gray">
                        <ImageView
                            android:src="@android:drawable/ic_menu_more"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                    <TextView
                        android:text="More"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="#1E2A38"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ── PROMO BANNER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/promoBanner"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:src="@drawable/promo"
                android:scaleType="centerCrop"
                android:background="@drawable/card_bg"/>
        </LinearLayout>

        <!-- ── FLASH DEALS (Horizontal Scroll) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="24dp">

            <!-- Section header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:text="🔥 Flash Deals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#1E2A38"/>

                <TextView
                    android:id="@+id/seeAllDeals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all ›"
                    android:textColor="#1A73E8"
                    android:textSize="13sp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <!-- Horizontal scroll of deal cards -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Deal Card 1 -->
                    <LinearLayout
                        android:id="@+id/Card1"
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_bg"
                        android:layout_marginEnd="10dp"
                        android:elevation="3dp">

                        <ImageView
                            android:layout_width="160dp"
                            android:layout_height="100dp"
                            android:src="@drawable/manila"
                            android:scaleType="centerCrop"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:text="Manila → Cebu"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1E2A38"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="From ₱1,299"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#E53935"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"/>

                            <TextView
                                android:text="One-way · Economy"
                                android:textSize="11sp"
                                android:textColor="#888888"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Deal Card 2 -->
                    <LinearLayout
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_bg"
                        android:layout_marginEnd="10dp"
                        android:elevation="3dp">

                        <ImageView
                            android:layout_width="160dp"
                            android:layout_height="100dp"
                            android:src="@drawable/singapore"
                            android:scaleType="centerCrop"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:text="Cebu → Singapore"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1E2A38"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="From ₱4,599"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#E53935"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"/>

                            <TextView
                                android:text="Round-trip · Economy"
                                android:textSize="11sp"
                                android:textColor="#888888"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Deal Card 3 -->
                    <LinearLayout
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_bg"
                        android:layout_marginEnd="10dp"
                        android:elevation="3dp">

                        <ImageView
                            android:layout_width="160dp"
                            android:layout_height="100dp"
                            android:src="@drawable/tc"
                            android:scaleType="centerCrop"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:text="Manila → Tokyo"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1E2A38"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="From ₱12,800"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#E53935"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"/>

                            <TextView
                                android:text="Round-trip · Economy"
                                android:textSize="11sp"
                                android:textColor="#888888"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Deal Card 4 -->
                    <LinearLayout
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_bg"
                        android:layout_marginEnd="4dp"
                        android:elevation="3dp">

                        <ImageView
                            android:layout_width="160dp"
                            android:layout_height="100dp"
                            android:src="@drawable/hk"
                            android:scaleType="centerCrop"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp">

                            <TextView
                                android:text="Cebu → Hong Kong"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1E2A38"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="From ₱8,350"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#E53935"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"/>

                            <TextView
                                android:text="One-way · Economy"
                                android:textSize="11sp"
                                android:textColor="#888888"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- ── GET INSPIRED (Horizontal Scroll) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="28dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="10dp">

                <TextView
                    android:text="✈️ Get Inspired"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="#1E2A38"/>

                <TextView
                    android:id="@+id/seeAllInspire"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all ›"
                    android:textColor="#1A73E8"
                    android:textSize="13sp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Inspire Card 1 -->
                    <FrameLayout
                        android:layout_width="140dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/card_bg"
                        android:elevation="3dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/boracay"
                            android:scaleType="centerCrop"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp"
                            android:layout_gravity="bottom"
                            android:background="#99000000">

                            <TextView
                                android:text="Boracay"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="Philippines"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </FrameLayout>

                    <!-- Inspire Card 2 -->
                    <FrameLayout
                        android:layout_width="140dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/card_bg"
                        android:elevation="3dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/bali"
                            android:scaleType="centerCrop"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp"
                            android:layout_gravity="bottom"
                            android:background="#99000000">

                            <TextView
                                android:text="Bali"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="Indonesia"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </FrameLayout>

                    <!-- Inspire Card 3 -->
                    <FrameLayout
                        android:layout_width="140dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/card_bg"
                        android:elevation="3dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/tc"
                            android:scaleType="centerCrop"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp"
                            android:layout_gravity="bottom"
                            android:background="#99000000">

                            <TextView
                                android:text="Tokyo"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="Japan"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </FrameLayout>

                    <!-- Inspire Card 4 -->
                    <FrameLayout
                        android:layout_width="140dp"
                        android:layout_height="180dp"
                        android:layout_marginEnd="4dp"
                        android:background="@drawable/card_bg"
                        android:elevation="3dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/singapore"
                            android:scaleType="centerCrop"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="10dp"
                            android:layout_gravity="bottom"
                            android:background="#99000000">

                            <TextView
                                android:text="Singapore"
                                android:textColor="#FFFFFF"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="Singapore"
                                android:textColor="#CCFFFFFF"
                                android:textSize="11sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </FrameLayout>
                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>

        <!-- ── MY BOOKINGS STRIP ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="28dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <TextView
                android:text="📋 My Bookings"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="#1E2A38"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"/>

            <ListView
                android:id="@+id/bookingsListView"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="@drawable/card_bg"
                android:divider="#EEEEEE"
                android:dividerHeight="1dp"
                android:elevation="2dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>