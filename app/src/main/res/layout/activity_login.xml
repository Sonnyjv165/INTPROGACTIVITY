<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/login"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/tropic"
    android:backgroundTint="#78FAFAFA"
    android:backgroundTintMode="screen">

    <!-- SCROLLABLE WRAPPER to handle small screens -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="48dp"
            android:paddingBottom="32dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- MAIN CARD -->
            <LinearLayout
                android:id="@+id/cardContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:background="@drawable/card_bg"
                android:backgroundTint="#E8F8FF"
                android:elevation="12dp"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- LOGO -->
                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center_horizontal"
                    android:scaleType="fitCenter"
                    app:srcCompat="@drawable/trip" />

                <!-- APP NAME -->
                <TextView
                    android:id="@+id/titleText1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:letterSpacing="0.15"
                    android:text="TRIP.COM"
                    android:textAlignment="center"
                    android:textColor="#0D1B2A"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- SUBTITLE -->
                <TextView
                    android:id="@+id/subtitleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="24dp"
                    android:text="Sign in to continue your journey"
                    android:textAlignment="center"
                    android:textColor="#607080"
                    android:textSize="13sp" />

                <!-- EMAIL LABEL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Email Address"
                    android:textColor="#2C3E50"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- EMAIL FIELD -->
                <EditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_bg"
                    android:drawableStart="@android:drawable/ic_dialog_email"
                    android:drawablePadding="8dp"
                    android:hint="you@example.com"
                    android:inputType="textEmailAddress"
                    android:padding="12dp"
                    android:textColor="@color/black"
                    android:textColorHint="#A0ADB8"
                    android:textSize="14sp" />

                <!-- PASSWORD LABEL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Password"
                    android:textColor="#2C3E50"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- PASSWORD FIELD CONTAINER -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <EditText
                        android:id="@+id/passwordInput"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/input_bg"
                        android:drawableStart="@android:drawable/ic_lock_lock"
                        android:drawablePadding="8dp"
                        android:hint="Enter your password"
                        android:inputType="textPassword"
                        android:paddingStart="12dp"
                        android:paddingEnd="52dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/black"
                        android:textColorHint="#A0ADB8"
                        android:textSize="14sp" />

                    <!-- SHOW/HIDE PASSWORD TOGGLE -->
                    <ImageButton
                        android:id="@+id/togglePassword"
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="end|center_vertical"
                        android:background="@android:color/transparent"
                        android:contentDescription="Toggle password visibility"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="#607080" />

                </FrameLayout>

                <!-- FORGOT PASSWORD (right-aligned) -->
                <TextView
                    android:id="@+id/forgotPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="end"
                    android:padding="4dp"
                    android:text="Forgot Password?"
                    android:textColor="#1A7FD4"
                    android:textSize="13sp" />

                <!-- LOGIN BUTTON -->
                <Button
                    android:id="@+id/loginBtn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="20dp"
                    android:background="@drawable/btn_blue"
                    android:letterSpacing="0.1"
                    android:text="SIGN IN"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- OR DIVIDER -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#C8D8E8" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:text="OR"
                        android:textColor="#90A4B4"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1"
                        android:background="#C8D8E8" />

                </LinearLayout>

                <!-- CONTINUE AS GUEST BUTTON -->

                <!-- REGISTER LINK -->
                <Button
                    android:id="@+id/guestBtn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/btn_gray"
                    android:drawableStart="@android:drawable/ic_menu_myplaces"
                    android:drawablePadding="8dp"
                    android:letterSpacing="0.05"
                    android:text="Continue as Guest"
                    android:textColor="#1A7FD4"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Don't have an account? "
                        android:textColor="#607080"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/registerText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Register"
                        android:textColor="#1A7FD4"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </RelativeLayout>
    </ScrollView>

</RelativeLayout>