<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/tropic"
    android:backgroundTint="#78FAFAFA"
    android:backgroundTintMode="screen"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <!-- ── SEARCH HEADER ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1A73E8"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="48dp"
            android:paddingBottom="20dp">

            <TextView
                android:text="✈️ Search Flights"
                android:textColor="#FFFFFF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Trip type tabs -->
            <LinearLayout
                android:id="@+id/tripTypeTabs"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:background="@drawable/tab_bg"
                android:layout_marginBottom="16dp">

                <RadioGroup
                    android:id="@+id/tripTypeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/oneWay"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="One-way"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:button="@null"
                        android:background="@drawable/tab_selected_bg"
                        android:checked="true" />

                    <RadioButton
                        android:id="@+id/roundTrip"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Round-trip"
                        android:textColor="#CCE8FF"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:button="@null" />

                    <RadioButton
                        android:id="@+id/multiCity"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Multi-city"
                        android:textColor="#CCE8FF"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:button="@null" />
                </RadioGroup>
            </LinearLayout>

            <!-- From / To inputs -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <!-- FROM -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/input_bg"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:text="FROM"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <EditText
                        android:id="@+id/fromInput"
                        android:hint="City or airport"
                        android:textColorHint="#BBBBBB"
                        android:textColor="#1E2A38"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:background="@null"
                        android:padding="0dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Swap button -->
                <FrameLayout
                    android:layout_width="36dp"
                    android:layout_height="50dp">

                    <ImageView
                        android:id="@+id/swapBtn"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_sort_by_size"
                        android:background="@drawable/circle_bg_blue_light"
                        android:padding="6dp"
                        app:tint="#FFFFFF" />
                </FrameLayout>

                <!-- TO -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/input_bg"
                    android:padding="12dp"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:text="TO"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <EditText
                        android:id="@+id/toInput"
                        android:hint="City or airport"
                        android:textColorHint="#BBBBBB"
                        android:textColor="#1E2A38"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:background="@null"
                        android:padding="0dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Date & Passenger row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="14dp">

                <!-- Date picker -->
                <LinearLayout
                    android:id="@+id/datePicker"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/input_bg"
                    android:padding="12dp"
                    android:layout_marginEnd="6dp">
                    <TextView
                        android:text="DEPARTURE"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/dateText"
                        android:text="Select date"
                        android:textColor="#1E2A38"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:drawableStart="@android:drawable/ic_menu_my_calendar"
                        android:drawablePadding="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- Passengers -->
                <LinearLayout
                    android:id="@+id/passengerPicker"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:background="@drawable/input_bg"
                    android:padding="12dp"
                    android:layout_marginStart="6dp">
                    <TextView
                        android:text="PASSENGERS"
                        android:textSize="10sp"
                        android:textColor="#888888"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                    <TextView
                        android:id="@+id/passengerText"
                        android:text="1 Adult · Economy"
                        android:textColor="#1E2A38"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:drawableStart="@android:drawable/ic_menu_myplaces"
                        android:drawablePadding="4dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Search button -->
            <Button
                android:id="@+id/searchBtn"
                android:text="Search Flights"
                android:textColor="#1A73E8"
                android:textStyle="bold"
                android:background="@drawable/btn_white_rounded"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>
        </LinearLayout>

        <!-- ── RESULTS SUMMARY BAR ── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="#F5F7FA"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/resultCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="128 flights found"
                android:textSize="13sp"
                android:textColor="#555555"
                android:layout_centerVertical="true"/>

            <ImageView
                android:id="@+id/filterBtn"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                app:tint="#1A73E8" />
        </RelativeLayout>

        <!-- ── SORT CHIPS (Horizontal Scroll) ── -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="#FFFFFF"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:clipToPadding="false"
            android:elevation="2dp">

            <RadioGroup
                android:id="@+id/filterGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/filterDefault"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Recommended"
                    android:textColor="#1A73E8"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/chip_selected"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginEnd="8dp"
                    android:checked="true"/>

                <RadioButton
                    android:id="@+id/filterPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Cheapest"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/chip_unselected"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginEnd="8dp"/>

                <RadioButton
                    android:id="@+id/filterTime"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Earliest"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/chip_unselected"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginEnd="8dp"/>

                <RadioButton
                    android:id="@+id/filterDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Shortest"
                    android:textColor="#555555"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:button="@null"
                    android:background="@drawable/chip_unselected"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"/>
            </RadioGroup>
        </HorizontalScrollView>

        <!-- ── FLIGHT CARDS LIST ── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/flightRecycler"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginTop="8dp" />

    </LinearLayout>
</ScrollView>