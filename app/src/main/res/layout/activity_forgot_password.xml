<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/tropic"
    android:backgroundTint="#78FAFAFA"
    android:backgroundTintMode="screen">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="48dp"
            android:paddingBottom="32dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <!-- MAIN CARD -->
            <LinearLayout
                android:id="@+id/cardContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:background="@drawable/card_bg"
                android:backgroundTint="#E8F8FF"
                android:elevation="12dp"
                android:orientation="vertical"
                android:padding="28dp">

                <!-- LOGO -->
                <ImageView
                    android:id="@+id/imageView"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_gravity="center_horizontal"
                    android:scaleType="fitCenter"
                    app:srcCompat="@drawable/trip" />

                <!-- LOCK ICON INDICATOR -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/circle_bg"
                    android:gravity="center"
                    android:padding="14dp"
                    android:text="🔒"
                    android:textSize="22sp" />

                <!-- TITLE -->
                <TextView
                    android:id="@+id/titleText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:letterSpacing="0.05"
                    android:text="Reset Password"
                    android:textAlignment="center"
                    android:textColor="#0D1B2A"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- SUBTITLE -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="24dp"
                    android:gravity="center"
                    android:text="Enter your email and a new password below"
                    android:textColor="#607080"
                    android:textSize="13sp" />

                <!-- EMAIL LABEL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Email Address"
                    android:textColor="#2C3E50"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- EMAIL FIELD -->
                <EditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/input_bg"
                    android:drawableStart="@android:drawable/ic_dialog_email"
                    android:drawablePadding="8dp"
                    android:hint="Registered email address"
                    android:inputType="textEmailAddress"
                    android:padding="12dp"
                    android:textColor="@color/black"
                    android:textColorHint="#A0ADB8"
                    android:textSize="14sp" />

                <!-- NEW PASSWORD LABEL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="New Password"
                    android:textColor="#2C3E50"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- NEW PASSWORD FIELD CONTAINER -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <EditText
                        android:id="@+id/newPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/input_bg"
                        android:drawableStart="@android:drawable/ic_lock_lock"
                        android:drawablePadding="8dp"
                        android:hint="Create a new password"
                        android:inputType="textPassword"
                        android:paddingStart="12dp"
                        android:paddingEnd="52dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/black"
                        android:textColorHint="#A0ADB8"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/toggleNewPassword"
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="end|center_vertical"
                        android:background="@android:color/transparent"
                        android:contentDescription="Toggle new password visibility"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="#607080" />

                </FrameLayout>

                <!-- REPEAT PASSWORD LABEL -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="6dp"
                    android:text="Confirm New Password"
                    android:textColor="#2C3E50"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- REPEAT PASSWORD FIELD CONTAINER -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">

                    <EditText
                        android:id="@+id/repeatPassword"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/input_bg"
                        android:drawableStart="@android:drawable/ic_lock_lock"
                        android:drawablePadding="8dp"
                        android:hint="Re-enter your new password"
                        android:inputType="textPassword"
                        android:paddingStart="12dp"
                        android:paddingEnd="52dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/black"
                        android:textColorHint="#A0ADB8"
                        android:textSize="14sp" />

                    <ImageButton
                        android:id="@+id/toggleRepeatPassword"
                        android:layout_width="48dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="end|center_vertical"
                        android:background="@android:color/transparent"
                        android:contentDescription="Toggle confirm password visibility"
                        android:src="@android:drawable/ic_menu_view"
                        app:tint="#607080" />

                </FrameLayout>

                <!-- SUBMIT BUTTON -->
                <Button
                    android:id="@+id/submitBtn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/btn_blue"
                    android:letterSpacing="0.1"
                    android:text="RESET PASSWORD"
                    android:textColor="@android:color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- BACK TO LOGIN LINK -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Remember your password? "
                        android:textColor="#607080"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/backToLogin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Back to Login"
                        android:textColor="#1A7FD4"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

        </RelativeLayout>
    </ScrollView>

</RelativeLayout>