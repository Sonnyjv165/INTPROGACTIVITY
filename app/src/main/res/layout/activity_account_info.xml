<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/tropic"
    android:backgroundTint="#78FAFAFA"
    android:backgroundTintMode="screen"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ── HEADER BAND ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1A73E8"
            android:paddingTop="48dp"
            android:paddingBottom="32dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Avatar circle -->
            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp">

                <ImageView
                    android:id="@+id/avatarImage"
                    android:layout_width="88dp"
                    android:layout_height="88dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:background="@drawable/circle_bg_white"
                    android:padding="18dp"
                    app:tint="#1A73E8" />

                <!-- Edit badge -->
                <FrameLayout
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/circle_bg_orange">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="#FFFFFF" />
                </FrameLayout>
            </FrameLayout>

            <TextView
                android:id="@+id/userNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Juan dela Cruz"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/emailText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="juan@email.com"
                android:textSize="13sp"
                android:textColor="#CCE8FF"
                android:layout_marginTop="4dp" />

            <!-- Member badge -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✦  Silver Member"
                android:background="@drawable/badge_bg"
                android:textColor="#FFD700"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginTop="10dp" />
        </LinearLayout>

        <!-- ── TRIP COINS STRIP ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:elevation="2dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/star_on"
                app:tint="#F5A623" />

            <TextView
                android:text=" TripCoins: "
                android:textColor="#555555"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tripCoinsText"
                android:text="2,480 pts"
                android:textColor="#1A73E8"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:text="Redeem ›"
                android:textColor="#1A73E8"
                android:textSize="13sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- ── ACCOUNT DETAILS CARD ── -->
        <TextView
            android:text="ACCOUNT DETAILS"
            android:textSize="11sp"
            android:textColor="#888888"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Full name row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/nameIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:layout_centerVertical="true"
                    app:tint="#1A73E8" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/nameIcon"
                    android:layout_marginStart="14dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:text="Full Name"
                        android:textSize="11sp"
                        android:textColor="#999999"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/fullNameText"
                        android:text="Juan dela Cruz"
                        android:textSize="14sp"
                        android:textColor="#1E2A38"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:tint="#AAAAAA" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <!-- Email row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/emailIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_dialog_email"
                    android:layout_centerVertical="true"
                    app:tint="#1A73E8" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/emailIcon"
                    android:layout_marginStart="14dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:text="Email"
                        android:textSize="11sp"
                        android:textColor="#999999"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/emailDetailText"
                        android:text="juan@email.com"
                        android:textSize="14sp"
                        android:textColor="#1E2A38"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:tint="#AAAAAA" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <!-- Phone row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/phoneIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_call"
                    android:layout_centerVertical="true"
                    app:tint="#1A73E8" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/phoneIcon"
                    android:layout_marginStart="14dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:text="Phone"
                        android:textSize="11sp"
                        android:textColor="#999999"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/phoneText"
                        android:text="+63 912 345 6789"
                        android:textSize="14sp"
                        android:textColor="#1E2A38"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:tint="#AAAAAA" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <!-- Password row -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/pwIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_lock_lock"
                    android:layout_centerVertical="true"
                    app:tint="#1A73E8" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_toEndOf="@id/pwIcon"
                    android:layout_marginStart="14dp"
                    android:layout_centerVertical="true">

                    <TextView
                        android:text="Password"
                        android:textSize="11sp"
                        android:textColor="#999999"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:id="@+id/passwordText"
                        android:text="••••••••"
                        android:textSize="16sp"
                        android:textColor="#1E2A38"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />
                </LinearLayout>

                <!-- Show/Hide toggle -->
                <TextView
                    android:id="@+id/togglePasswordBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show"
                    android:textColor="#1A73E8"
                    android:textSize="13sp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true" />
            </RelativeLayout>
        </LinearLayout>

        <!-- ── PREFERENCES SECTION ── -->
        <TextView
            android:text="PREFERENCES"
            android:textSize="11sp"
            android:textColor="#888888"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Notifications -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/notifIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    android:layout_centerVertical="true"
                    app:tint="#666666" />

                <TextView
                    android:text="Notifications"
                    android:textSize="14sp"
                    android:textColor="#1E2A38"
                    android:layout_toEndOf="@id/notifIcon"
                    android:layout_marginStart="14dp"
                    android:layout_centerVertical="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <Switch
                    android:id="@+id/notifSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:checked="true" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <!-- Language -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/langIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/globe"
                    android:layout_centerVertical="true" />

                <TextView
                    android:text="Language"
                    android:textSize="14sp"
                    android:textColor="#1E2A38"
                    android:layout_toEndOf="@id/langIcon"
                    android:layout_marginStart="14dp"
                    android:layout_centerVertical="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="English ›"
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <!-- Currency -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/currIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_today"
                    android:layout_centerVertical="true"
                    app:tint="#666666" />

                <TextView
                    android:text="Currency"
                    android:textSize="14sp"
                    android:textColor="#1E2A38"
                    android:layout_toEndOf="@id/currIcon"
                    android:layout_marginStart="14dp"
                    android:layout_centerVertical="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <TextView
                    android:text="PHP (₱) ›"
                    android:textSize="13sp"
                    android:textColor="#AAAAAA"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </RelativeLayout>
        </LinearLayout>

        <!-- ── SUPPORT SECTION ── -->
        <TextView
            android:text="SUPPORT"
            android:textSize="11sp"
            android:textColor="#888888"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingTop="22dp"
            android:paddingBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Help Center -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/helpIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_help"
                    android:layout_centerVertical="true"
                    app:tint="#666666" />

                <TextView
                    android:text="Help Center"
                    android:textSize="14sp"
                    android:textColor="#1E2A38"
                    android:layout_toEndOf="@id/helpIcon"
                    android:layout_marginStart="14dp"
                    android:layout_centerVertical="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_media_next"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:tint="#CCCCCC" />
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0F0F0" />

            <!-- Privacy Policy -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/privacyIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_lock_lock"
                    android:layout_centerVertical="true"
                    app:tint="#666666" />

                <TextView
                    android:text="Privacy Policy"
                    android:textSize="14sp"
                    android:textColor="#1E2A38"
                    android:layout_toEndOf="@id/privacyIcon"
                    android:layout_marginStart="14dp"
                    android:layout_centerVertical="true"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@android:drawable/ic_media_next"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    app:tint="#CCCCCC" />
            </RelativeLayout>
        </LinearLayout>

        <!-- ── ACTION BUTTONS ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp">

            <Button
                android:id="@+id/backBtn"
                android:text="Back to Dashboard"
                android:background="@drawable/btn_blue"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:layout_width="match_parent"
                android:layout_height="50dp"/>

            <Button
                android:id="@+id/logoutBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Log Out"
                android:layout_marginTop="12dp"
                android:background="@drawable/btn_outline_red"
                android:textColor="#E53935"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- App version -->
        <TextView
            android:text="TripGo v1.0.0"
            android:textSize="11sp"
            android:textColor="#CCCCCC"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:layout_marginTop="20dp"/>

    </LinearLayout>
</ScrollView>